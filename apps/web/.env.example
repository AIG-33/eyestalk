NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Search Console verification token (the value of the
# `content` attribute from the meta-tag method, without quotes).
# Used for OAuth Consent Screen branding verification + Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google OAuth Web client (the same one configured in Supabase Dashboard
# under Auth → Providers → Google). Not consumed by our current code —
# Supabase performs the OAuth dance — but kept here for reference and
# future server-side Google APIs.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
