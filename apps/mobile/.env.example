EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Use the canonical host (www) so bearer-authenticated requests are never sent
# through an apex->www redirect that could strip the Authorization header.
EXPO_PUBLIC_API_URL=https://www.eyestalk.app/api/v1

# Google OAuth Web client ID (kept for reference; the actual OAuth flow
# goes through Supabase, which holds the secret server-side).
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
