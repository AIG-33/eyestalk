{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "CXXFLAGS": "-Wno-deprecated-declarations",
        "CFLAGS": "-Wno-deprecated-declarations"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "beta",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      },
      "ios": {
        "ascApiKeyPath": "./credentials/AppStoreConnect_ApiKey.p8",
        "ascApiKeyId": "TRS8NZAGX5",
        "ascApiKeyIssuerId": "31303d35-0acc-4d1a-89d4-872e31f2b28f"
      }
    },
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
