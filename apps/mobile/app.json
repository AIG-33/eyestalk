{
  "expo": {
    "name": "EyesTalk",
    "slug": "eyestalk",
    "owner": "gmaxby",
    "version": "0.1.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/420dd9b0-8ec5-40a8-a937-2acb2c65fedf"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "eyestalk",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eyestalk.app",
      "associatedDomains": [
        "applinks:eyestalk.app"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "EyesTalk needs your location to find venues near you and verify check-ins.",
        "NSCameraUsageDescription": "EyesTalk needs camera access to scan QR codes for venue check-in.",
        "NSPhotoLibraryUsageDescription": "EyesTalk needs photo library access to set your profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.eyestalk.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "eyestalk.app",
              "pathPrefix": "/venue"
            },
            {
              "scheme": "https",
              "host": "eyestalk.app",
              "pathPrefix": "/chat"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "EyesTalk needs your location to find venues near you."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "EyesTalk needs camera access to scan QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6C5CE7"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "EyesTalk needs photo library access to set your profile picture."
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "420dd9b0-8ec5-40a8-a937-2acb2c65fedf"
      }
    }
  }
}
